# LLM Backend: ollama (default), openai, azure_openai, dummy
AGENT_BACKEND="ollama"

# Model name configuration:
# - For openai: defaults to "gpt-5.4-nano"
# - For ollama: defaults to "gemma4:latest"
# - For azure_openai: defaults to "gpt-5.4-nano"
AGENT_MODEL="gemma4:latest"

# LLM API Host Endpoint:
# - For openai: leave empty for official API (https://api.openai.com/v1)
# - For ollama: defaults to "http://127.0.0.1:11434"
# - For azure_openai: base endpoint URL (e.g. "https://<resource>.openai.azure.com/")
AGENT_ENDPOINT="http://127.0.0.1:11434"

# --- OpenAI Backend Configuration ---
# Required if AGENT_BACKEND="openai" and using official endpoint
OPENAI_API_KEY=""

# --- Azure OpenAI Backend Configuration ---
# Required if AGENT_BACKEND="azure_openai"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2025-04-01-preview"

# --- Context Capture Configuration ---
# AGENT_TMUX_LINES=50          # Lines captured from active tmux scrollback
# AGENT_HISTORY_COMMANDS=20    # History commands captured if tmux is not active

# --- Agent Behavior Configuration ---
# AGENT_THINKING_LEVEL="off"   # Thinking level: off (default), low, medium, high (for reasoning models)

